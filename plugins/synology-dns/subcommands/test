#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x

source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"

PASS=0
FAIL=0

check() {
  local desc="$1"; shift
  if "$@" &>/dev/null 2>&1; then
    dokku_log_info1 "PASS: $desc"
    ((PASS++)) || true
  else
    dokku_log_warn "FAIL: $desc"
    ((FAIL++)) || true
  fi
}

dokku_log_info2 "synology-dns tests"

NAMED_BASE="/var/packages/DNSServer/target/named"
RELOAD_DIR="/reload"
SYNO_DNS_ZONE="$(dokku config:get --global SYNO_DNS_ZONE 2>/dev/null || true)"

check "named base directory exists"      test -d "$NAMED_BASE"
check "zone directory exists"            test -d "${NAMED_BASE}/etc/zone/master"
check "reload trigger directory exists"  test -d "$RELOAD_DIR"
check "SYNO_DNS_ZONE configured"         test -n "$SYNO_DNS_ZONE"
check "SYNO_NAS_IP configured"           test -n "$(dokku config:get --global SYNO_NAS_IP 2>/dev/null || true)"

if [[ -n "$SYNO_DNS_ZONE" ]]; then
  check "zone file exists" test -f "${NAMED_BASE}/etc/zone/master/${SYNO_DNS_ZONE}"
fi

# Verify rndc-sidecar is responding
if [[ -d "$RELOAD_DIR" ]]; then
  TRIGGER="${RELOAD_DIR}/.dokku-dns-test"
  touch "$TRIGGER"
  sleep 3
  if [[ ! -f "$TRIGGER" ]]; then
    dokku_log_info1 "PASS: rndc-sidecar is running"
    ((PASS++)) || true
  else
    dokku_log_warn "FAIL: rndc-sidecar did not respond (is it running?)"
    rm -f "$TRIGGER"
    ((FAIL++)) || true
  fi
fi

dokku_log_info1 "Results: ${PASS} passed, ${FAIL} failed"
[[ "$FAIL" -eq 0 ]]
