#!/usr/bin/env bash
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x
source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"
source "$PLUGIN_AVAILABLE_PATH/config/functions"

APP="$1"
CONF_DIR="/usr/local/etc/nginx/conf.d"
CONF_FILE="${CONF_DIR}/dokku-${APP}.conf"
NGINX_PID_FILE="/run/nginx.pid"

# Resolve the app's vhost(s)
VHOSTS="$(dokku domains:report "$APP" --domains-app-vhosts 2>/dev/null || true)"
if [[ -z "$VHOSTS" ]]; then
  dokku_log_warn "synology-proxy: no vhosts configured for $APP, skipping"
  exit 0
fi

# Get upstream port — Dokku assigns this
PORT="$(plugn trigger proxy-is-enabled "$APP" 2>/dev/null | head -1 || true)"
if [[ -z "$PORT" ]]; then
  # Fall back: find the first mapped host port for the app's web container
  PORT="$(docker inspect --format '{{range $p, $conf := .NetworkSettings.Ports}}{{if $conf}}{{(index $conf 0).HostPort}}{{end}}{{end}}' "$(dokku ps:inspect "$APP" 2>/dev/null | jq -r '.[] | select(.Name | test("web")) | .Id' 2>/dev/null || true)" 2>/dev/null | head -1 || true)"
fi

if [[ -z "$PORT" ]]; then
  dokku_log_warn "synology-proxy: could not determine upstream port for $APP"
  exit 1
fi

UPSTREAM="127.0.0.1:${PORT}"

dokku_log_info1 "synology-proxy: writing nginx conf for $APP → $UPSTREAM"

# Build server blocks for all vhosts
{
  for VHOST in $VHOSTS; do
    cat <<NGINX
server {
    listen 80;
    server_name ${VHOST};

    access_log /var/log/nginx/dokku-${APP}.access.log;
    error_log  /var/log/nginx/dokku-${APP}.error.log;

    location / {
        proxy_pass http://${UPSTREAM};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_read_timeout 60s;
        proxy_connect_timeout 10s;
    }
}
NGINX
  done
} > "$CONF_FILE"

# Reload DSM's nginx
if [[ -f "$NGINX_PID_FILE" ]]; then
  nginx -s reload
  dokku_log_info1 "synology-proxy: nginx reloaded"
else
  dokku_log_warn "synology-proxy: nginx pid not found at $NGINX_PID_FILE, skipping reload"
fi
